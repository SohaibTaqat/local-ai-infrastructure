{
  "uid": "model-performance",
  "title": "Model Performance (vLLM)",
  "tags": ["vllm", "models", "gpu"],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "15s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "definition": "label_values(vllm:kv_cache_usage_perc, model_name)",
        "name": "model",
        "label": "Model",
        "type": "query",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "gauge",
      "title": "KV Cache Usage",
      "description": "GPU KV cache utilization. When this hits 100%, requests start queuing.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "vllm:kv_cache_usage_perc{model_name=~\"$model\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Requests Running",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 3, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "vllm:num_requests_running{model_name=~\"$model\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Requests Waiting",
      "description": "Queue depth. Non-zero means the model is at capacity.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 3, "x": 9, "y": 1 },
      "targets": [
        {
          "expr": "vllm:num_requests_waiting{model_name=~\"$model\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Requests Completed",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(vllm:request_success_total{model_name=~\"$model\"}[5m]))",
          "legendFormat": "Last 5m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [ { "color": "blue", "value": null } ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Token Throughput",
      "description": "Prompt and generation tokens per second.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "rate(vllm:prompt_tokens_total{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} — prompt tok/s"
        },
        {
          "expr": "rate(vllm:generation_tokens_total{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} — gen tok/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "End-to-End Request Latency",
      "description": "p50, p95, p99 of total request time.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Time to First Token (TTFT)",
      "description": "p50, p95, p99 — how long users wait before seeing output.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Inter-Token Latency",
      "description": "Time between successive output tokens. Affects streaming UX.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "row",
      "title": "Queue & Cache",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Queue Wait Time",
      "description": "How long requests sit in the queue before processing starts.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:request_queue_time_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:request_queue_time_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "KV Cache Usage Over Time",
      "description": "Track cache pressure trends. Sustained >90% means you need more capacity.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 },
      "targets": [
        {
          "expr": "vllm:kv_cache_usage_perc{model_name=~\"$model\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Prefix Cache Hit Rate",
      "description": "Ratio of cache hits to total queries. Higher = faster repeated prompts.",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 },
      "targets": [
        {
          "expr": "rate(vllm:prefix_cache_hits_total{model_name=~\"$model\"}[5m]) / clamp_min(rate(vllm:prefix_cache_queries_total{model_name=~\"$model\"}[5m]), 1)",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "row",
      "title": "GPU (DCGM)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "GPU Utilization",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GPU Memory Used",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 26 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "GPU {{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GPU Temperature",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 26 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "GPU {{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GPU Power Usage",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 26 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "GPU {{gpu}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}

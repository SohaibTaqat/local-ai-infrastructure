{
  "uid": "model-performance",
  "title": "Model Performance (vLLM)",
  "tags": [
    "vllm",
    "models",
    "gpu"
  ],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "15s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(vllm:kv_cache_usage_perc, model_name)",
        "query": "label_values(vllm:kv_cache_usage_perc, model_name)",
        "name": "model",
        "label": "Model",
        "type": "query",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "regex": "",
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "gauge",
      "title": "KV Cache Usage",
      "description": "GPU KV cache utilization. When this hits 100%, requests start queuing.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "max_over_time(vllm:kv_cache_usage_perc{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Requests Running",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 3,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "expr": "max_over_time(vllm:num_requests_running{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Requests Waiting",
      "description": "Queue depth. Non-zero means the model is at capacity.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 3,
        "x": 9,
        "y": 1
      },
      "targets": [
        {
          "expr": "max_over_time(vllm:num_requests_waiting{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Requests Completed",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(increase(vllm:request_success_total{model_name=~\"$model\"}[$__range]))",
          "legendFormat": "Total in window"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Concurrent Requests Over Time",
      "description": "In-flight requests (running) + queued (waiting) per model. Hover any past timestamp to see exact concurrency at that moment, then cross-reference with KV cache, GPU, and latency panels below.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "expr": "max_over_time(vllm:num_requests_running{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}} — running"
        },
        {
          "expr": "max_over_time(vllm:num_requests_waiting{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}} — waiting"
        },
        {
          "expr": "sum by (model_name) (max_over_time(vllm:num_requests_running{model_name=~\"$model\"}[1m]) + max_over_time(vllm:num_requests_waiting{model_name=~\"$model\"}[1m]))",
          "legendFormat": "{{model_name}} — cluster total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*cluster total.*"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    8,
                    4
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "stat",
      "title": "Peak Concurrency (window)",
      "description": "Highest total in-flight requests observed within the dashboard's selected time range.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 7
      },
      "targets": [
        {
          "expr": "max_over_time(sum by (model_name) (vllm:num_requests_running{model_name=~\"$model\"} + vllm:num_requests_waiting{model_name=~\"$model\"})[$__range:])",
          "legendFormat": "{{model_name}} cluster peak"
        },
        {
          "expr": "avg_over_time(sum by (model_name) (vllm:num_requests_running{model_name=~\"$model\"} + vllm:num_requests_waiting{model_name=~\"$model\"})[$__range:])",
          "legendFormat": "{{model_name}} cluster avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      }
    },
    {
      "type": "timeseries",
      "title": "Token Throughput",
      "description": "Prompt and generation tokens per second.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "rate(vllm:prompt_tokens_total{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}} \u2014 prompt tok/s"
        },
        {
          "expr": "rate(vllm:generation_tokens_total{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}} \u2014 gen tok/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Throughput & Errors",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate (RPS)",
      "description": "Successfully completed requests per second, per replica + cluster total. Includes all finish reasons (stop, length, abort, error).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(vllm:request_success_total{model_name=~\"$model\"}[1m]))",
          "legendFormat": "{{instance}}"
        },
        {
          "expr": "sum (rate(vllm:request_success_total{model_name=~\"$model\"}[1m]))",
          "legendFormat": "cluster total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cluster total"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    8,
                    4
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "stat",
      "title": "Error Rate (5m)",
      "description": "Percentage of completed requests with finished_reason=error over a rolling 5m window. Sustained values >1% warrant investigation.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum(rate(vllm:request_success_total{model_name=~\"$model\", finished_reason=\"error\"}[5m])) / clamp_min(sum(rate(vllm:request_success_total{model_name=~\"$model\"}[5m])), 1)",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "Finish Reasons",
      "description": "Stacked breakdown of completed requests by reason. error/abort indicate problems, stop is normal, length means hit max_tokens.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (finished_reason) (rate(vllm:request_success_total{model_name=~\"$model\"}[1m]))",
          "legendFormat": "{{finished_reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "stop"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "length"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "abort"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "repetition"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "Preemptions (per second)",
      "description": "vLLM evicting in-progress requests due to KV cache pressure. Any sustained non-zero value means the model is past capacity — requests are being silently restarted, inflating latency without showing as errors.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(vllm:num_preemptions_total{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.001
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "End-to-End Request Latency",
      "description": "p50, p95, p99 of total request time.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Time to First Token (TTFT)",
      "description": "p50, p95, p99 \u00e2\u20ac\u201d how long users wait before seeing output.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 25
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Inter-Token Latency",
      "description": "Time between successive output tokens. Affects streaming UX.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 25
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:inter_token_latency_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Queue & Cache",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Queue Wait Time",
      "description": "How long requests sit in the queue before processing starts.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:request_queue_time_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:request_queue_time_seconds_bucket{model_name=~\"$model\"}[5m])) by (le, model_name, instance))",
          "legendFormat": "{{model_name}} @ {{instance}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "KV Cache Usage Over Time",
      "description": "Track cache pressure trends. Sustained >90% means you need more capacity.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 34
      },
      "targets": [
        {
          "expr": "max_over_time(vllm:kv_cache_usage_perc{model_name=~\"$model\"}[1m])",
          "legendFormat": "{{model_name}} @ {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Prefix Cache Hit Rate",
      "description": "Ratio of cache hits to total queries. Higher = faster repeated prompts.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 34
      },
      "targets": [
        {
          "expr": "rate(vllm:prefix_cache_hits_total{model_name=~\"$model\"}[5m]) / clamp_min(rate(vllm:prefix_cache_queries_total{model_name=~\"$model\"}[5m]), 1)",
          "legendFormat": "{{model_name}} @ {{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,

# ============================================================
# Local AI Infrastructure — Environment Variables
# Copy to .env and customize before running: docker compose up -d
# ============================================================

# --- Postgres (shared by LiteLLM + Langfuse) ---
POSTGRES_VERSION=16
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm

# --- LiteLLM Gateway ---
LITELLM_VERSION=main-stable
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-change-me

# --- Langfuse (LLM Observability) ---
LANGFUSE_VERSION=3
LANGFUSE_PORT=3001
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_NEXTAUTH_SECRET=change-me-nextauth-secret
LANGFUSE_SALT=change-me-salt
# Optional: auto-initialize org, project, and admin user on first run
# LANGFUSE_INIT_ORG_NAME=MyCompany
# LANGFUSE_INIT_PROJECT_NAME=default
# LANGFUSE_INIT_USER_EMAIL=admin@example.com
# LANGFUSE_INIT_USER_PASSWORD=changeme
# LANGFUSE_INIT_USER_NAME=Admin

# --- ClickHouse (Langfuse analytics backend) ---
CLICKHOUSE_VERSION=24.12
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=langfuse

# --- Redis (Langfuse cache/queue) ---
REDIS_VERSION=7

# --- SeaweedFS (S3-compatible blob storage for Langfuse) ---
SEAWEEDFS_VERSION=latest
S3_ACCESS_KEY=langfuse
S3_SECRET_KEY=langfuse

# --- Prometheus ---
PROMETHEUS_VERSION=v3.10.0
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# --- Loki ---
GRAFANA_LOKI_VERSION=3.6.7
LOKI_PORT=3100

# --- Grafana ---
GRAFANA_VERSION=12.4.0
GRAFANA_PORT=3000

# --- DCGM Exporter (GPU metrics) ---
DCGM_EXPORTER_VERSION=3.3.9-3.6.1-ubuntu22.04
DCGM_PORT=9400

# --- Alloy (metrics + log collector) ---
GRAFANA_ALLOY_VERSION=v1.14.0
ALLOY_PORT=12345
